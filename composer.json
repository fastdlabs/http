{
  "name": "fastd/http",
  "description": "FastD Http",
  "license": "MIT",
  "type": "library",
  "minimum-stability": "dev",
  "keywords": ["FastD", "swoole", "psr7", "http-message", "http"],
  "authors": [
    {
      "name": "janhuang",
      "email": "384099566@qq.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-zlib": "*",
    "psr/http-message": "^2.0",
    "psr/http-factory": "*",
    "psr/http-client": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "fastd/swoole": "dev-develop",
    "swoole/ide-helper": "@dev"
  },
  "autoload": {
    "psr-4": {
      "FastD\\Http\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Swoole\\Http\\": "tests/swoole/http"
    }
  }
}
